# Runtime environment
EXPO_PUBLIC_ENV=development

# API & CDN
EXPO_PUBLIC_API_URL=https://api.fitflow-demo.example.com/api
EXPO_PUBLIC_DO_HOST=https://cdn.fitflow-demo.example.com

# Deep links & sharing
EXPO_PUBLIC_DEEP_LINK_HOST=fitflow-demo.example.com
EXPO_PUBLIC_APP_SCHEME=fitflow
EXPO_PUBLIC_APP_LINK=https://fitflow-demo.example.com/app

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=fitflow-demo.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=fitflow-demo
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=fitflow-demo.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Third-party integrations
EXPO_PUBLIC_APPSFLYER_DEV_KEY=your-appsflyer-dev-key
EXPO_PUBLIC_APPSFLYER_APP_ID=your-appsflyer-app-id
EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
EXPO_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# EAS 
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
