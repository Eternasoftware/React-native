{
  "cli": {
    "version": ">= 13.2.1",
    "appVersionSource": "local",
    "promptToConfigurePushNotifications": false
  },

  "build": {
    "base": {
      "node": "22.14.0",
      "cache": {
        "disabled": false
      }
    },

    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_ENV": "development"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      }
    },

    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },

    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_ENV": "staging"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },

    "preview-apk": {
      "extends": "preview",
      "android": {
        "buildType": "apk"
      }
    },

    "production": {
      "extends": "base",
      "distribution": "store",
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_ENV": "production"
      },
      "ios": {
        "image": "latest",
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": false
      }
    }
  },

  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "track": "production",
        "releaseStatus": "completed"
      }
    },
    "preview": {
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
